# NewsHub — variables de entorno (copiar a .env)

# --- Servidor ---
PORT=4000
NODE_ENV=development

# --- Base de datos (Postgres 17) ---
# Dev local con docker-compose (puerto 5434):
DATABASE_URL=postgresql://newshub:newshub_dev@localhost:5434/newshub

# --- Ingesta ---
# Token que protege POST /api/ingest (lo usa el cron de Coolify).
INGEST_TOKEN=dev-ingest-token-change-me

# --- News API (opcional, conector newsapi) — proveedor elegido: GNews ---
# https://gnews.io  (o newsapi para newsapi.org)
NEWSAPI_PROVIDER=gnews
NEWSAPI_KEY=

# --- Embeddings (servicio self-hosted newshub-embed) ---
# Dev local con docker-compose: http://localhost:8089
EMBED_URL=http://localhost:8089
# Token compartido para proteger /embed (opcional pero recomendado en prod):
EMBED_TOKEN=

# --- Web Push (VAPID) ---
# Genera el par con:  pnpm --filter @newshub/web exec web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:leugim8a@gmail.com
# La clave pública también se expone al cliente:
NEXT_PUBLIC_VAPID_PUBLIC_KEY=

# --- App ---
NEXT_PUBLIC_APP_URL=http://localhost:4000
